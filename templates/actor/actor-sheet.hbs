<section class="tirakan-sheet">
  <header class="sheet-header">
    <img class="portrait" src="{{actor.img}}" data-edit="img" data-action="editImage" title="{{actor.name}}" />
    <div class="identity">
      <div class="title-line">
        {{#if editIdentity}}
          <input class="name" data-update="name" type="text" value="{{actor.name}}" />
          <button type="button" class="tiny-edit" data-action="doneEdit">{{localize "TIRAKAN.Action.Done"}}</button>
        {{else}}
          <h1>{{actor.name}}</h1>
          <button type="button" class="tiny-edit" data-action="editSection" data-section="identity"><i class="fa-solid fa-pen"></i></button>
        {{/if}}
      </div>
      <div class="identity-grid">
        {{#if isCharacter}}
          <label>
            <span>{{localize "TIRAKAN.Field.Player"}}</span>
            {{#if editIdentity}}<input data-update="system.playerName" type="text" value="{{system.playerName}}" />{{else}}<strong>{{system.playerName}}</strong>{{/if}}
          </label>
          <label>
            <span>{{localize "TIRAKAN.Field.Campaign"}}</span>
            {{#if editIdentity}}<input data-update="system.campaign" type="text" value="{{system.campaign}}" />{{else}}<strong>{{system.campaign}}</strong>{{/if}}
          </label>
          <label>
            <span>{{localize "TIRAKAN.Field.Ancestry"}}</span>
            {{#if editIdentity}}<input data-update="system.ancestry" type="text" value="{{system.ancestry}}" list="tirakan-ancestries" />{{else}}<strong class="identity-value">{{system.ancestry}}{{#if ancestryInfo}}<span class="mark-info"><button type="button" class="icon-button mark-info-button" aria-label="{{system.ancestry}}"><i class="fa-solid fa-circle-info"></i></button><span class="mark-info-popover"><b>{{ancestryInfo.name}}</b>{{#each ancestryInfo.rows}}<span><span class="mark-info-label">{{label}}</span>{{value}}</span>{{/each}}</span></span>{{/if}}</strong>{{/if}}
          </label>
          <label>
            <span>{{localize "TIRAKAN.Field.Path"}}</span>
            {{#if editIdentity}}<input data-update="system.path" type="text" value="{{system.path}}" list="tirakan-paths" />{{else}}<strong class="identity-value">{{system.path}}{{#if pathInfo}}<span class="mark-info"><button type="button" class="icon-button mark-info-button" aria-label="{{system.path}}"><i class="fa-solid fa-circle-info"></i></button><span class="mark-info-popover"><b>{{pathInfo.name}}</b>{{#each pathInfo.rows}}<span><span class="mark-info-label">{{label}}</span>{{value}}</span>{{/each}}</span></span>{{/if}}</strong>{{/if}}
          </label>
          <label>
            <span>{{localize "TIRAKAN.Field.Bond"}}</span>
            {{#if editIdentity}}<input data-update="system.bond" type="text" value="{{system.bond}}" list="tirakan-bonds" />{{else}}<strong class="identity-value">{{system.bond}}{{#if bondInfo}}<span class="mark-info"><button type="button" class="icon-button mark-info-button" aria-label="{{system.bond}}"><i class="fa-solid fa-circle-info"></i></button><span class="mark-info-popover"><b>{{bondInfo.name}}</b>{{#each bondInfo.rows}}<span><span class="mark-info-label">{{label}}</span>{{value}}</span>{{/each}}</span></span>{{/if}}</strong>{{/if}}
          </label>
          <label>
            <span>{{localize "TIRAKAN.Field.Century"}}</span>
            {{#if editIdentity}}<input data-update="system.century" type="number" min="1" max="10" value="{{system.century}}" />{{else}}<strong>{{system.century}}</strong>{{/if}}
          </label>
        {{else}}
          <label>
            <span>{{localize "TIRAKAN.Field.Role"}}</span>
            {{#if editIdentity}}<input data-update="system.role" type="text" value="{{system.role}}" />{{else}}<strong>{{system.role}}</strong>{{/if}}
          </label>
          <label>
            <span>{{localize "TIRAKAN.Field.Instinct"}}</span>
            {{#if editIdentity}}<input data-update="system.instinct" type="text" value="{{system.instinct}}" />{{else}}<strong>{{system.instinct}}</strong>{{/if}}
          </label>
        {{/if}}
      </div>
    </div>
  </header>

  <datalist id="tirakan-ancestries">{{#each config.ancestries}}<option value="{{this}}"></option>{{/each}}</datalist>
  <datalist id="tirakan-paths">{{#each config.paths}}<option value="{{this}}"></option>{{/each}}</datalist>
  <datalist id="tirakan-bonds">{{#each config.bonds}}<option value="{{this}}"></option>{{/each}}</datalist>

  <div class="sheet-tab-layout">
    <nav class="sheet-tabs" aria-label="{{localize 'TIRAKAN.Tab.Navigation'}}">
      {{#each tabs}}
        <button type="button" class="sheet-tab" data-action="changeTab" data-tab="{{id}}" data-active="{{active}}" title="{{label}}" aria-label="{{label}}">
          <i class="{{icon}}"></i>
        </button>
      {{/each}}
    </nav>

    <main class="sheet-pages">
      <section class="sheet-page sheet-grid" data-tab="core" data-active="{{activeCoreTab}}">
        <section class="panel attributes">
          <h2><span>{{localize "TIRAKAN.Section.Attributes"}}</span>{{#if editAttributes}}<button type="button" class="tiny-edit" data-action="doneEdit">{{localize "TIRAKAN.Action.Done"}}</button>{{else}}<button type="button" class="tiny-edit" data-action="editSection" data-section="attributes"><i class="fa-solid fa-pen"></i></button>{{/if}}</h2>
          {{#each attributeRows}}
            <div class="sheet-rank-row">
              <button type="button" data-action="rollAttribute" data-attribute="{{key}}" title="{{localize 'TIRAKAN.Roll.Roll'}}">
                <i class="fa-solid fa-dice"></i>
              </button>
              <div class="rank-label"><strong>{{label}}</strong></div>
              <div class="rank-circles">
                {{#each circles}}
                  {{#if ../editing}}
                    <button type="button" class="rank-circle attribute-circle" data-action="setAttribute" data-attribute="{{../key}}" data-value="{{value}}" data-selected="{{selected}}">{{value}}</button>
                  {{else}}
                    <span class="rank-circle attribute-circle" data-readonly="true" data-selected="{{selected}}">{{value}}</span>
                  {{/if}}
                {{/each}}
              </div>
            </div>
          {{/each}}
        </section>

        <section class="panel resources">
          <h2><span>{{localize "TIRAKAN.Section.Consequences"}}</span>{{#if editResources}}<button type="button" class="tiny-edit" data-action="doneEdit">{{localize "TIRAKAN.Action.Done"}}</button>{{else}}<button type="button" class="tiny-edit" data-action="editSection" data-section="resources"><i class="fa-solid fa-pen"></i></button>{{/if}}</h2>
          {{#each resourceRows}}
            <div class="condition-row">
              <strong>{{label}}</strong>
              <div class="condition-circles">
                {{#each circles}}
                  {{#if ../editing}}
                    <button type="button" class="rank-circle condition-circle" data-action="setResource" data-resource="{{../key}}" data-value="{{value}}" data-selected="{{selected}}">{{value}}</button>
                  {{else}}
                    <span class="rank-circle condition-circle" data-readonly="true" data-selected="{{selected}}">{{value}}</span>
                  {{/if}}
                {{/each}}
              </div>
            </div>
          {{/each}}
          <div class="derived">
            <span>{{localize "TIRAKAN.Derived.Initiative"}} {{system.derived.initiative}}</span>
            <span>{{localize "TIRAKAN.Derived.Faith"}} {{system.derived.faithLevel}}</span>
            <span>{{localize "TIRAKAN.Derived.Magic"}} {{system.derived.magicLevel}}</span>
          </div>
          <div class="conditions">
            <h3><span>{{localize "TIRAKAN.Section.Conditions"}}</span>{{#if editConditions}}<button type="button" class="tiny-edit" data-action="doneEdit">{{localize "TIRAKAN.Action.Done"}}</button>{{else}}<button type="button" class="tiny-edit" data-action="editSection" data-section="conditions"><i class="fa-solid fa-pen"></i></button>{{/if}}</h3>
            {{#each conditionOptions}}
              {{#if editing}}
                <button type="button" data-action="{{action}}" data-condition="{{key}}" class="condition-pill {{#if active}}active{{/if}}">{{label}}</button>
              {{else}}
                <span class="condition-pill {{#if active}}active{{/if}}">{{label}}</span>
              {{/if}}
            {{/each}}
          </div>
        </section>
      </section>

      <section class="sheet-page" data-tab="skills" data-active="{{activeSkillsTab}}">
        <section class="panel skills">
          <h2><span>{{localize "TIRAKAN.Section.Skills"}}</span>{{#if editSkills}}<button type="button" class="tiny-edit" data-action="doneEdit">{{localize "TIRAKAN.Action.Done"}}</button>{{else}}<button type="button" class="tiny-edit" data-action="editSection" data-section="skills"><i class="fa-solid fa-pen"></i></button>{{/if}}</h2>
          {{#each skillRows}}
            <div class="skill-rank-row">
              {{#if editing}}
                <input data-update="system.skills.{{index}}.name" type="text" value="{{name}}" />
              {{else}}
                <strong>{{name}}</strong>
              {{/if}}
              <div class="rank-circles">
                {{#each circles}}
                  {{#if ../editing}}
                    <button type="button" class="rank-circle" data-action="setSkillRank" data-index="{{../index}}" data-value="{{value}}" data-selected="{{selected}}">{{value}}</button>
                  {{else}}
                    <span class="rank-circle" data-readonly="true" data-selected="{{selected}}">{{value}}</span>
                  {{/if}}
                {{/each}}
              </div>
              {{#if editing}}
                <button type="button" class="icon-button" data-action="removeSkill" data-index="{{index}}" title="{{localize 'TIRAKAN.Action.Remove'}}"><i class="fa-solid fa-trash"></i></button>
              {{/if}}
            </div>
          {{/each}}
          {{#if editSkills}}<button type="button" class="add-button" data-action="addSkill"><i class="fa-solid fa-plus"></i> {{localize "TIRAKAN.Action.AddSkill"}}</button>{{/if}}
        </section>
      </section>

      <section class="sheet-page" data-tab="spells" data-active="{{activeSpellsTab}}">
        <section class="panel spells">
          <h2>
            <span>{{localize "TIRAKAN.Section.Spells"}}</span>
            <span class="rule-info">
              <button type="button" class="tiny-edit rule-info-button" aria-label="{{localize 'TIRAKAN.Magic.CastingRules'}}"><i class="fa-solid fa-circle-info"></i></button>
              <span class="rule-popover">
                <strong>{{localize "TIRAKAN.Magic.CastingRules"}}</strong>
                <span>{{localize "TIRAKAN.Magic.Rule.Flow"}}</span>
                <span>{{localize "TIRAKAN.Magic.Rule.Low"}}</span>
                <span>{{localize "TIRAKAN.Magic.Rule.Normal"}}</span>
                <span>{{localize "TIRAKAN.Magic.Rule.Hard"}}</span>
                <span>{{localize "TIRAKAN.Magic.Rule.Catastrophic"}}</span>
                <span>{{localize "TIRAKAN.Magic.Rule.Roll"}}</span>
                <span>{{localize "TIRAKAN.Magic.Rule.Results"}}</span>
              </span>
            </span>
          </h2>
          <div class="spell-list">
            {{#if hasSpellRows}}
              {{#each spellRows}}
                <article class="spell-row">
                  <div class="spell-row-title">
                    <strong>{{name}}</strong>
                    <span>{{aspect}}</span>
                    <div class="spell-tags">
                      {{#if category}}<span>{{category}}</span>{{/if}}
                      {{#if element}}<span>{{element}}</span>{{/if}}
                    </div>
                  </div>
                  <dl class="spell-metrics">
                    {{#each metrics}}
                      <div data-metric="{{key}}"><dt>{{label}}</dt><dd>{{value}}</dd></div>
                    {{/each}}
                  </dl>
                  <div class="spell-card-actions">
                    {{#if description}}
                      <span class="spell-info">
                        <button type="button" class="icon-button spell-info-button" aria-label="{{name}}"><i class="fa-solid fa-circle-info"></i></button>
                        <span class="spell-info-popover">{{description}}</span>
                      </span>
                    {{/if}}
                    <button type="button" class="icon-button" data-action="rollSpell" data-spell-index="{{index}}" data-spell-name="{{name}}" title="{{localize 'TIRAKAN.Magic.CastSpell'}}"><i class="fa-solid fa-dice-d20"></i></button>
                  </div>
                </article>
              {{/each}}
            {{else}}
              <p class="empty-state">{{localize "TIRAKAN.Spell.None"}}</p>
            {{/if}}
          </div>
        </section>
      </section>

      <section class="sheet-page" data-tab="notes" data-active="{{activeNotesTab}}">
        <section class="panel notes">
          <h2><span>{{localize "TIRAKAN.Section.Notes"}}</span>{{#if editNotes}}<button type="button" class="tiny-edit" data-action="doneEdit">{{localize "TIRAKAN.Action.Done"}}</button>{{else}}<button type="button" class="tiny-edit" data-action="editSection" data-section="notes"><i class="fa-solid fa-pen"></i></button>{{/if}}</h2>
          {{#if editNotes}}
            <textarea data-update="system.notes">{{system.notes}}</textarea>
          {{else}}
            <div class="notes-view">{{{system.notes}}}</div>
          {{/if}}
        </section>
      </section>
    </main>
  </div>
</section>
